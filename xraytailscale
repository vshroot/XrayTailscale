github_raw_curl() {
  local url="$1"
  shift

  if [[ -n "$GITHUB_RAW_AUTH_TOKEN" ]]; then
    curl -fsSL -H "Authorization: Bearer ${GITHUB_RAW_AUTH_TOKEN}" "$@" "$url"
  else
    curl -fsSL "$@" "$url"
  fi
}

