    (.inbounds[] | select(.port == $port) | .streamSettings.realitySettings.fingerprint) |= $fp
  ' "$CONFIG_FILE"; then
    echo -e "${RED}✗ Ошибка обновления config.json${NC}"
    sleep 2
    return
