}
TCPMUXEOF
)
      ;;
    tcp|tcp-utls|tcp-xudp)
      inbound=$(cat << TCPEOF
{
  "listen": "0.0.0.0",
  "port": $port,
  "protocol": "vless",
  "settings": {
